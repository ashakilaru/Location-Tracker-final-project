<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="LocationTrackerApp.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Location Heat Tracker"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="Capture your movement, save it to SQLite, and see the trail appear as a live heat-map overlay."
                   LineBreakMode="WordWrap" />

            <Label x:Name="StatusLabel"
                   Text="Ready to track"
                   FontAttributes="Italic" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="Start Tracking"
                        Clicked="OnStartTrackingClicked" />
                <Button Grid.Column="1"
                        Text="Stop Tracking"
                        Clicked="OnStopTrackingClicked" />
            </Grid>

            <Button Text="Clear History"
                    Clicked="OnClearClicked" />

            <maps:Map x:Name="LocationMap"
                      HeightRequest="420" />

            <Label x:Name="SummaryLabel"
                   Text="Saved points: 0" />

            <CollectionView x:Name="RecentLocationsView"
                            HeightRequest="140"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8"
                                Margin="0,4"
                                StrokeShape="RoundRectangle 8">
                            <Label Text="{Binding .}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
